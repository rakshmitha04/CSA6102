            "URL: http://192.168.1.10/login\n",
            "Classification: Suspicious\n",
            "- Uses HTTP\n"
          ]
        }
      ],
      "source": [
        "from urllib.parse import urlparse\n",
        "\n",
        "urls = [\n",
        "    \"https://paypal.com/login\",\n",
        "    \"https://paypa1-login-security.com/verify\",\n",
        "    \"http://192.168.1.10/login\"\n",
        "]\n",
        "\n",
        "trusted_domains = [\"paypal.com\"]\n",
        "\n",
        "for url in urls:\n",
        "    domain = urlparse(url).netloc\n",
        "\n",
        "    print(\"\\nURL:\", url)\n",
        "\n",
        "    if domain in trusted_domains:\n",
        "        print(\"Classification: Legitimate\")\n",
        "    else:\n",
        "        print(\"Classification: Suspicious\")\n",
        "\n",
        "        if \"-\" in domain:\n",
        "            print(\"- Hyphen found\")\n",
        "\n",
        "        if url.startswith(\"http://\"):\n",
        "            print(\"- Uses HTTP\")\n",
        "\n",
        "        if \"paypa1\" in domain:\n",
        "            print(\"- Possible Typosquatting\")"
      ]
    }
  ]
