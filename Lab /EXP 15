        "import re\n",
        "from urllib.parse import urlparse\n",
        "\n",
        "body = \"\"\"\n",
        "Click here:\n",
        "https://paypa1-login-security.com/verify\n",
        "\n",
        "Visit:\n",
        "http://192.168.1.10/login\n",
        "\"\"\"\n",
        "\n",
        "urls = re.findall(r'https?://[^\\s]+', body)\n",
        "\n",
        "print(\"Extracted URLs:\")\n",
        "\n",
        "for url in urls:\n",
        "    domain = urlparse(url).netloc\n",
        "    print(\"URL:\", url)\n",
        "    print(\"Domain:\", domain)"
      ]
