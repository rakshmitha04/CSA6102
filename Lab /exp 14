      "source": [
        "import re\n",
        "\n",
        "email = {\n",
        "    \"From\": \"PayPal Support <support@paypa1.com>\",\n",
        "    \"Reply-To\": \"security@paypa1.com\",\n",
        "    \"Subject\": \"Urgent: Verify Your Account\"\n",
        "}\n",
        "\n",
        "trusted_domains = [\"paypal.com\", \"google.com\", \"amazon.com\"]\n",
        "\n",
        "match = re.search(r'<(.*?)>', email[\"From\"])\n",
        "sender = match.group(1)\n",
        "\n",
        "sender_domain = sender.split(\"@\")[-1]\n",
        "\n",
        "print(\"Sender Email:\", sender)\n",
        "print(\"Sender Domain:\", sender_domain)\n",
        "print(\"Reply-To:\", email[\"Reply-To\"])\n",
        "print(\"Subject:\", email[\"Subject\"])\n",
        "\n",
        "if sender_domain in trusted_domains:\n",
        "    print(\"Status: Legitimate Sender\")\n",
        "else:\n",
        "    print(\"Status: Spoofed/Suspicious Sender\")"
      ]
    }
